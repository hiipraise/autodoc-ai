# ── AI Provider ──────────────────────────────────────────
# Get your FREE Groq API key at https://console.groq.com
# Free tier: 6,000 requests/day, blazing fast inference
GROQ_API_KEY=gsk_your_key_here

# Ollama (local, completely free, no API key needed)
# Install: https://ollama.ai → pull codellama:7b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=codellama:7b

# ── Server ────────────────────────────────────────────────
SERVER_PORT=4000
FRONTEND_URL=http://localhost:3000

# ── AutoDoc ───────────────────────────────────────────────
AUTODOC_DEFAULT_MODEL=llama3-70b-8192
AUTODOC_WATCH_DEBOUNCE_MS=1500