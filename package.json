{
  "name": "autodoc-ai",
  "version": "1.0.0",
   "packageManager": "npm@11.4.2",
  "description": "AI-powered README generator with live watch mode",
  "private": true,
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "*"
  },
  "workspaces": [
    "packages/*",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n CLI,SERVER,WEB -c yellow,cyan,magenta \"npm run dev:cli\" \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:cli": "npm -w packages/cli run dev",
    "dev:frontend": "npm -w packages/frontend run dev",
    "dev:server": "npm -w server run dev",
    "build": "npm -w packages/cli run build && npm -w server run build && npm -w packages/frontend run build",
    "test": "npm -w packages/cli run test",
    "lint": "eslint \"packages/*/src/**/*.{ts,tsx}\" \"server/src/**/*.ts\"",
    "typecheck": "tsc --noEmit -p packages/cli/tsconfig.json && tsc --noEmit -p packages/frontend/tsconfig.json",
    "clean": "rimraf packages/*/dist server/dist packages/frontend/dist"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "browserslist": "^4.28.1",
    "caniuse-lite": "^1.0.30001775",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
