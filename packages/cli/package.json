{
  "name": "@autodoc-ai/cli",
  "version": "1.0.0",
  "description": "AI-powered README generator CLI",
  "bin": {
    "autodoc": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format cjs,esm --dts --shims",
    "test": "vitest run"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cosmiconfig": "^9.0.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.3.0",
    "groq-sdk": "^0.3.0",
    "ignore": "^5.3.0",
    "lodash.debounce": "^4.0.8",
    "ora": "^8.0.0",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/lodash.debounce": "^4.0.9",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "vitest": "^4.0.18"
  }
}
